# Admin credentials (required for login)
ADMIN_USER=
ADMIN_PASSWORD=

# Google Sheets URL (main spreadsheet)
# GSHEETS_URL=https://docs.google.com/spreadsheets/d/your-sheet-id-here

# Path to Google service account JSON file
# GOOGLE_SERVICE_ACCOUNT_PATH=/path/to/google_service_account.json

# API base URLs (defaults work for local dev)
# API_BASE_URL=http://localhost/api
# ADMIN_API_BASE_URL=http://localhost/admin/api
# AUTH_API_URL=http://localhost/api/user

# Token file location
# TOKEN_FILE=~/.opencode-token
